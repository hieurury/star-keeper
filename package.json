{
  "name": "ban-may-bay",
  "private": true,
  "version": "2.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "icons:android": "node scripts/generate-android-icons.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "mobile:android": "npm run cap:sync:android && npm run cap:open:android",
    "mobile:ios": "npm run cap:sync:ios && npm run cap:open:ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@phosphor-icons/vue": "^2.2.1",
    "@supabase/supabase-js": "^2.102.1",
    "pinia": "^3.0.4",
    "pixi.js": "^8.17.0",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^3.1.5"
  }
}
